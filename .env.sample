# Copy this file to .env and adjust values for your environment.
# Never commit the real .env file.

# --- Logging ---
LOG_LEVEL=INFO

# --- Model artifact locations (populated by the training scripts) ---
MODEL_SENTIMENT_PATH=models/sentiment_roberta
MODEL_TOPIC_MODEL_PATH=models/bertopic_model
MODEL_TOPIC_CLASSIFIER_PATH=models/topic_classifier

# --- Data locations ---
RAW_DATA_DIR=raw_data
PROCESSED_DATA_DIR=raw_data/processed

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Dashboard ---
DASHBOARD_API_BASE_URL=http://localhost:8000
