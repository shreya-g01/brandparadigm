# Standard python ignores
*.egg-info
.coverage
.ipynb_checkpoints
**/__pycache__/
.python-version
*.pyc
**/build
.pytest_cache/
.ruff_cache/
*.egg

# Ignore these macos generated files
.DS_Store

# Ignore these Windows generated files
*Zone.Identifier

# Ignore VS Code / IDE generated files
.vscode/
.idea/

# Raw data (large historical datasets pulled by scripts/download_datasets.py)
raw_data/*
!raw_data/.gitkeep
*.csv
*.sqlite
*.zip
*.parquet

# Saved models / checkpoints
models/*
!models/.gitkeep
*.joblib
*.h5
*.bin
*.safetensors
*.pt

# Any pickle files
*.pickle
*.pckl
*.pkl

# Credentials (or files with potentially credentials inside)
.env
.env.yaml
.credentials
secrets.toml

# Only ignore JSON that holds credentials or generated run output, never
# tracked configs/metrics/notebook metadata.
*.credentials.json
*.secrets.json
mlruns/
wandb/

# User defined extras
