# Standard python ignores
*.egg-info
.coverage
.ipynb_checkpoints
**/__pycache__/
.python-version
*.pyc
**/build
.pytest_cache/
.ruff_cache/
*.egg

# Ignore these macos generated files
.DS_Store

# Ignore these Windows generated files
*Zone.Identifier

# Ignore VS Code / IDE generated files
.vscode/
.idea/

# Raw data (large historical datasets pulled by scripts/download_datasets.py).
# Ignoring the directory itself covers every file/extension underneath it
# (including nested subfolders) — no extension-based rules needed here, so
# tracked fixtures elsewhere in the repo (e.g. tests/fixtures/*.csv) are
# never accidentally caught by an overly broad *.csv-style pattern.
raw_data/*
!raw_data/.gitkeep

# Saved models / checkpoints — same reasoning, directory-scoped only.
models/*
!models/.gitkeep

# Any pickle files
*.pickle
*.pckl
*.pkl

# Credentials (or files with potentially credentials inside)
.env
.env.yaml
.credentials
secrets.toml

# Only ignore JSON that holds credentials or generated run output, never
# tracked configs/metrics/notebook metadata.
*.credentials.json
*.secrets.json
mlruns/
wandb/


/bparadigm/
*.backup.csv
*.old.csv
# User defined extras
